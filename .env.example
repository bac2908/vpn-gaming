# =====================================================
# VPN GAMING APP - Environment Variables
# Copy this file to .env and update values
# cp .env.example .env
# =====================================================

# =====================================================
# DATABASE
# =====================================================
DB_USER=vpn_user
DB_PASSWORD=change-this-db-password
DB_NAME=vpn_app
DB_HOST=database
DB_PORT=5432
DB_DRIVER=psycopg2

# Option 1 (recommended): để trống DATABASE_URL và dùng DB_* ở trên
DATABASE_URL=

# Option 2: khai báo DATABASE_URL trực tiếp (nếu cần)
# Lưu ý: nếu password có ký tự đặc biệt (@, #, /, :) thì phải URL-encode
# Ví dụ container: postgresql+psycopg2://vpn_user:myP%40ss%23123@database:5432/vpn_app
# Ví dụ host:      postgresql+psycopg2://vpn_user:myP%40ss%23123@host.docker.internal:5432/vpn_app

# =====================================================
# JWT AUTHENTICATION
# =====================================================
# QUAN TRỌNG: Thay đổi secret key này trong production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALG=HS256
JWT_EXPIRE_MIN=30

# =====================================================
# APP URLS
# =====================================================
# APP_BASE_URL: URL công khai của backend (dùng cho email links, OAuth callback)
# - Nếu dùng nginx reverse proxy: http://your-domain.com (port 80)
# - Nếu truy cập backend trực tiếp: http://your-domain.com:8080
APP_BASE_URL=http://your-domain.com

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Startup seeding (chỉ dùng cho lần khởi tạo DB trống)
SEED_DEFAULT_DATA=true
SEED_ADMIN_EMAIL=admin@vpngaming.com
SEED_ADMIN_PASSWORD=change-this-admin-password

# VITE_API_BASE_URL: URL để Frontend gọi API
# - Production (nginx proxy): để trống hoặc không set
# - Development: http://localhost:8080
VITE_API_BASE_URL=

# CORS - Danh sách các domain được phép (phân cách bằng dấu phẩy)
CORS_ORIGINS=http://your-domain.com,https://your-domain.com

# =====================================================
# EMAIL (SMTP)
# =====================================================
SMTP_FALLBACK_TO_CONSOLE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true

# =====================================================
# GOOGLE OAUTH (Optional)
# =====================================================
# Tạo credentials tại: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google callback qua nginx proxy (port 80)
GOOGLE_REDIRECT_URI=http://your-domain.com/auth/google/callback

# =====================================================
# MOMO PAYMENT (Optional)
# =====================================================
# Đăng ký tại: https://business.momo.vn/
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# MoMo redirect và IPN qua nginx proxy
MOMO_REDIRECT_URL=http://your-domain.com/app/topup/result
MOMO_IPN_URL=http://your-domain.com/payments/momo/ipn
MOMO_REQUEST_TYPE=payWithMethod
MOMO_DEMO_AUTO_CONFIRM=false
