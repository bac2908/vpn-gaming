# =====================================================
# BACKEND ENV CONFIGURATION
# Copy this file to .env and update values for your environment
# cp .env.example .env
# =====================================================

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
# Option 1 (recommended): use DB_* values, app will build DATABASE_URL automatically
DB_USER=vpn_user
DB_PASSWORD=change-this-db-password
DB_NAME=vpn_app
DB_HOST=localhost
DB_PORT=5432
DB_DRIVER=psycopg2

# Option 2: set full connection string directly
# If password contains special chars (@, #, /, :), URL-encode it
# Example: postgresql+psycopg2://vpn_user:myP%40ss%23123@localhost:5432/vpn_app
DATABASE_URL=

# =====================================================
# JWT AUTHENTICATION
# =====================================================
# IMPORTANT: Change this secret in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALG=HS256
JWT_EXPIRE_MIN=30

# =====================================================
# APPLICATION URLS
# =====================================================
# Backend public URL (used for email links, OAuth callbacks)
# Development: http://localhost:8080
# Production with nginx: http://your-domain.com
APP_BASE_URL=http://localhost:8080

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Startup seeding (for first run on an empty database)
SEED_DEFAULT_DATA=true
SEED_ADMIN_EMAIL=admin@vpngaming.com
SEED_ADMIN_PASSWORD=change-this-admin-password

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,http://localhost:8080

# =====================================================
# EMAIL (SMTP) CONFIGURATION
# =====================================================
# For development, set SMTP_FALLBACK_TO_CONSOLE=true to log emails to console
SMTP_FALLBACK_TO_CONSOLE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@your-domain.com
SMTP_USE_TLS=true
VERIFICATION_EXPIRE_MIN=30

# =====================================================
# GOOGLE OAUTH (Optional)
# =====================================================
# Create OAuth credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# =====================================================
# MOMO PAYMENT (Optional - Test Mode)
# =====================================================
# Get credentials from MoMo developer portal
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=F8BBA842ECF85
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://localhost:8080/app/topup/result
MOMO_IPN_URL=http://localhost:8080/payments/momo/ipn
MOMO_REQUEST_TYPE=payWithMethod
